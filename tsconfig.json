{
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "noImplicitAny": true,
    "module": "commonjs",
    "target": "es2021",
    "lib": [
      "es2021"
    ],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": [
    "./"
  ]
}